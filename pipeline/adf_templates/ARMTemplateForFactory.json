{
    "$schema": "http://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
    "contentVersion": "1.0.0.0",
    "parameters": {
        "factoryName": {
            "type": "string",
            "metadata": "Data Factory name",
            "defaultValue": "retail-vendor-adf"
        },
        "ls_blob_bronze_connectionString": {
            "type": "secureString",
            "metadata": "Secure string for 'connectionString' of 'ls_blob_bronze'"
        },
        "ls_sql_database_password": {
            "type": "secureString",
            "metadata": "Secure string for 'password' of 'ls_sql_database'"
        },
        "ls_sql_database_properties_typeProperties_server": {
            "type": "string",
            "defaultValue": "retailvendorsrv2026.database.windows.net"
        },
        "ls_sql_database_properties_typeProperties_database": {
            "type": "string",
            "defaultValue": "retail-vendor-db"
        },
        "ls_sql_database_properties_typeProperties_userName": {
            "type": "string",
            "defaultValue": "sqladmin"
        }
    },
    "variables": {
        "factoryId": "[concat('Microsoft.DataFactory/factories/', parameters('factoryName'))]"
    },
    "resources": [
        {
            "name": "[concat(parameters('factoryName'), '/ls_blob_bronze')]",
            "type": "Microsoft.DataFactory/factories/linkedServices",
            "apiVersion": "2018-06-01",
            "properties": {
                "annotations": [],
                "type": "AzureBlobStorage",
                "typeProperties": {
                    "connectionString": "[parameters('ls_blob_bronze_connectionString')]"
                }
            },
            "dependsOn": []
        },
        {
            "name": "[concat(parameters('factoryName'), '/ls_sql_database')]",
            "type": "Microsoft.DataFactory/factories/linkedServices",
            "apiVersion": "2018-06-01",
            "properties": {
                "annotations": [],
                "type": "AzureSqlDatabase",
                "typeProperties": {
                    "server": "[parameters('ls_sql_database_properties_typeProperties_server')]",
                    "database": "[parameters('ls_sql_database_properties_typeProperties_database')]",
                    "encrypt": "mandatory",
                    "trustServerCertificate": false,
                    "authenticationType": "SQL",
                    "userName": "[parameters('ls_sql_database_properties_typeProperties_userName')]",
                    "password": {
                        "type": "SecureString",
                        "value": "[parameters('ls_sql_database_password')]"
                    }
                }
            },
            "dependsOn": []
        },
        {
            "name": "[concat(parameters('factoryName'), '/df_top_vendors')]",
            "type": "Microsoft.DataFactory/factories/dataflows",
            "apiVersion": "2018-06-01",
            "properties": {
                "type": "MappingDataFlow",
                "typeProperties": {
                    "sources": [
                        {
                            "dataset": {
                                "referenceName": "ds_purchases",
                                "type": "DatasetReference"
                            },
                            "name": "purchases"
                        }
                    ],
                    "sinks": [
                        {
                            "dataset": {
                                "referenceName": "ds_gold_top_vendors",
                                "type": "DatasetReference"
                            },
                            "name": "sinkTopVendors"
                        }
                    ],
                    "transformations": [
                        {
                            "name": "aggTopVendors"
                        }
                    ],
                    "scriptLines": [
                        "source(output(",
                        "          InventoryId as string,",
                        "          Store as string,",
                        "          Brand as string,",
                        "          Description as string,",
                        "          Size as string,",
                        "          VendorNumber as string,",
                        "          VendorName as string,",
                        "          PONumber as string,",
                        "          PODate as string,",
                        "          ReceivingDate as string,",
                        "          InvoiceDate as string,",
                        "          PayDate as string,",
                        "          PurchasePrice as string,",
                        "          Quantity as string,",
                        "          Dollars as string,",
                        "          Classification as string",
                        "     ),",
                        "     allowSchemaDrift: true,",
                        "     validateSchema: false,",
                        "     ignoreNoFilesFound: false) ~> purchases",
                        "purchases aggregate(groupBy(VendorNumber,",
                        "          VendorName),",
                        "     TotalPurchaseDollars = sum(toDouble(Dollars)),",
                        "          {TotalQuantity } = sum(toInteger(Quantity)),",
                        "          {AvgPurchasePrice } = avg(toDouble(PurchasePrice))) ~> aggTopVendors",
                        "aggTopVendors sink(allowSchemaDrift: true,",
                        "     validateSchema: false,",
                        "     input(",
                        "          VendorNumber as integer,",
                        "          VendorName as string,",
                        "          TotalPurchaseDollars as double,",
                        "          TotalQuantity as integer,",
                        "          AvgPurchasePrice as double",
                        "     ),",
                        "     deletable:false,",
                        "     insertable:true,",
                        "     updateable:false,",
                        "     upsertable:false,",
                        "     truncate:true,",
                        "     format: 'table',",
                        "     skipDuplicateMapInputs: true,",
                        "     skipDuplicateMapOutputs: true,",
                        "     errorHandlingOption: 'stopOnFirstError') ~> sinkTopVendors"
                    ]
                }
            },
            "dependsOn": [
                "[concat(variables('factoryId'), '/datasets/ds_purchases')]",
                "[concat(variables('factoryId'), '/datasets/ds_gold_top_vendors')]"
            ]
        },
        {
            "name": "[concat(parameters('factoryName'), '/df_vendor_sales_contribution')]",
            "type": "Microsoft.DataFactory/factories/dataflows",
            "apiVersion": "2018-06-01",
            "properties": {
                "type": "MappingDataFlow",
                "typeProperties": {
                    "sources": [
                        {
                            "dataset": {
                                "referenceName": "ds_sales",
                                "type": "DatasetReference"
                            },
                            "name": "sales"
                        }
                    ],
                    "sinks": [
                        {
                            "dataset": {
                                "referenceName": "ds_gold_vendor_sales_contribution",
                                "type": "DatasetReference"
                            },
                            "name": "sinkSalesContribution"
                        }
                    ],
                    "transformations": [
                        {
                            "name": "aggSalesContribution"
                        },
                        {
                            "name": "calcContribution"
                        }
                    ],
                    "scriptLines": [
                        "source(output(",
                        "          InventoryId as string,",
                        "          Store as string,",
                        "          Brand as string,",
                        "          Description as string,",
                        "          Size as string,",
                        "          SalesQuantity as string,",
                        "          SalesDollars as string,",
                        "          SalesPrice as string,",
                        "          SalesDate as string,",
                        "          Volume as string,",
                        "          Classification as string,",
                        "          ExciseTax as string,",
                        "          VendorNo as string,",
                        "          VendorName as string",
                        "     ),",
                        "     allowSchemaDrift: true,",
                        "     validateSchema: false,",
                        "     ignoreNoFilesFound: false) ~> sales",
                        "sales aggregate(groupBy(VendorNo,",
                        "          VendorName),",
                        "     TotalSalesDollars = sum(toDouble(SalesDollars))) ~> aggSalesContribution",
                        "aggSalesContribution derive(SalesContributionPct = toDouble(TotalSalesDollars) * 100) ~> calcContribution",
                        "calcContribution sink(allowSchemaDrift: true,",
                        "     validateSchema: false,",
                        "     input(",
                        "          VendorNumber as integer,",
                        "          VendorName as string,",
                        "          TotalSalesDollars as double,",
                        "          SalesContributionPct as double",
                        "     ),",
                        "     deletable:false,",
                        "     insertable:true,",
                        "     updateable:false,",
                        "     upsertable:false,",
                        "     truncate:true,",
                        "     format: 'table',",
                        "     skipDuplicateMapInputs: true,",
                        "     skipDuplicateMapOutputs: true,",
                        "     errorHandlingOption: 'stopOnFirstError') ~> sinkSalesContribution"
                    ]
                }
            },
            "dependsOn": [
                "[concat(variables('factoryId'), '/datasets/ds_sales')]",
                "[concat(variables('factoryId'), '/datasets/ds_gold_vendor_sales_contribution')]"
            ]
        },
        {
            "name": "[concat(parameters('factoryName'), '/df_inventory_gap')]",
            "type": "Microsoft.DataFactory/factories/dataflows",
            "apiVersion": "2018-06-01",
            "properties": {
                "type": "MappingDataFlow",
                "typeProperties": {
                    "sources": [
                        {
                            "dataset": {
                                "referenceName": "ds_begin_inventory",
                                "type": "DatasetReference"
                            },
                            "name": "beginInventory"
                        },
                        {
                            "dataset": {
                                "referenceName": "ds_end_inventory",
                                "type": "DatasetReference"
                            },
                            "name": "endInventory"
                        }
                    ],
                    "sinks": [
                        {
                            "dataset": {
                                "referenceName": "ds_gold_inventory_gap",
                                "type": "DatasetReference"
                            },
                            "name": "sinkInventoryGap"
                        }
                    ],
                    "transformations": [
                        {
                            "name": "joinInventory"
                        },
                        {
                            "name": "calcInventoryGap"
                        }
                    ],
                    "scriptLines": [
                        "source(output(",
                        "          InventoryId as string,",
                        "          Store as string,",
                        "          City as string,",
                        "          Brand as string,",
                        "          Description as string,",
                        "          Size as string,",
                        "          onHand as string,",
                        "          Price as string,",
                        "          startDate as string",
                        "     ),",
                        "     allowSchemaDrift: true,",
                        "     validateSchema: false,",
                        "     ignoreNoFilesFound: false) ~> beginInventory",
                        "source(output(",
                        "          InventoryId as string,",
                        "          Store as string,",
                        "          City as string,",
                        "          Brand as string,",
                        "          Description as string,",
                        "          Size as string,",
                        "          onHand as string,",
                        "          Price as string,",
                        "          endDate as string",
                        "     ),",
                        "     allowSchemaDrift: true,",
                        "     validateSchema: false,",
                        "     ignoreNoFilesFound: false) ~> endInventory",
                        "beginInventory, endInventory join(beginInventory@InventoryId == endInventory@InventoryId",
                        "     && beginInventory@Store == endInventory@Store,",
                        "     joinType:'inner',",
                        "     matchType:'exact',",
                        "     ignoreSpaces: false,",
                        "     broadcast: 'auto')~> joinInventory",
                        "joinInventory derive(InventoryGap = toInteger(endInventory@onHand) - toInteger(beginInventory@onHand)) ~> calcInventoryGap",
                        "calcInventoryGap sink(allowSchemaDrift: true,",
                        "     validateSchema: false,",
                        "     input(",
                        "          InventoryId as string,",
                        "          Store as integer,",
                        "          Brand as integer,",
                        "          Description as string,",
                        "          BeginOnHand as integer,",
                        "          EndOnHand as integer,",
                        "          InventoryGap as integer",
                        "     ),",
                        "     deletable:false,",
                        "     insertable:true,",
                        "     updateable:false,",
                        "     upsertable:false,",
                        "     truncate:true,",
                        "     format: 'table',",
                        "     skipDuplicateMapInputs: true,",
                        "     skipDuplicateMapOutputs: true,",
                        "     errorHandlingOption: 'stopOnFirstError') ~> sinkInventoryGap"
                    ]
                }
            },
            "dependsOn": [
                "[concat(variables('factoryId'), '/datasets/ds_begin_inventory')]",
                "[concat(variables('factoryId'), '/datasets/ds_end_inventory')]",
                "[concat(variables('factoryId'), '/datasets/ds_gold_inventory_gap')]"
            ]
        },
        {
            "name": "[concat(parameters('factoryName'), '/df_invoice_reconciliation')]",
            "type": "Microsoft.DataFactory/factories/dataflows",
            "apiVersion": "2018-06-01",
            "properties": {
                "type": "MappingDataFlow",
                "typeProperties": {
                    "sources": [
                        {
                            "dataset": {
                                "referenceName": "ds_purchases",
                                "type": "DatasetReference"
                            },
                            "name": "purchases2"
                        },
                        {
                            "dataset": {
                                "referenceName": "ds_vendor_invoice",
                                "type": "DatasetReference"
                            },
                            "name": "vendorInvoice"
                        }
                    ],
                    "sinks": [
                        {
                            "dataset": {
                                "referenceName": "ds_gold_invoice_reconciliation",
                                "type": "DatasetReference"
                            },
                            "name": "sinkReconciliation"
                        }
                    ],
                    "transformations": [
                        {
                            "name": "joinInvoice"
                        },
                        {
                            "name": "aggReconciliation"
                        }
                    ],
                    "scriptLines": [
                        "source(output(",
                        "          InventoryId as string,",
                        "          Store as string,",
                        "          Brand as string,",
                        "          Description as string,",
                        "          Size as string,",
                        "          VendorNumber as string,",
                        "          VendorName as string,",
                        "          PONumber as string,",
                        "          PODate as string,",
                        "          ReceivingDate as string,",
                        "          InvoiceDate as string,",
                        "          PayDate as string,",
                        "          PurchasePrice as string,",
                        "          Quantity as string,",
                        "          Dollars as string,",
                        "          Classification as string",
                        "     ),",
                        "     allowSchemaDrift: true,",
                        "     validateSchema: false,",
                        "     ignoreNoFilesFound: false) ~> purchases2",
                        "source(output(",
                        "          VendorNumber as string,",
                        "          VendorName as string,",
                        "          InvoiceDate as string,",
                        "          PONumber as string,",
                        "          PODate as string,",
                        "          PayDate as string,",
                        "          Quantity as string,",
                        "          Dollars as string,",
                        "          Freight as string,",
                        "          Approval as string",
                        "     ),",
                        "     allowSchemaDrift: true,",
                        "     validateSchema: false,",
                        "     ignoreNoFilesFound: false) ~> vendorInvoice",
                        "purchases2, vendorInvoice join(purchases2@PONumber == vendorInvoice@PONumber,",
                        "     joinType:'inner',",
                        "     matchType:'exact',",
                        "     ignoreSpaces: false,",
                        "     broadcast: 'auto')~> joinInvoice",
                        "joinInvoice aggregate(groupBy(purchases2@VendorNumber,",
                        "          purchases2@VendorName,",
                        "          purchases2@PONumber),",
                        "     PurchaseDollars = sum(toDouble(purchases2@Dollars)),",
                        "          InvoiceDollars = sum(toDouble(vendorInvoice@Dollars)),",
                        "          Variance = sum(toDouble(purchases2@Dollars)) - sum(toDouble(vendorInvoice@Dollars))) ~> aggReconciliation",
                        "aggReconciliation sink(allowSchemaDrift: true,",
                        "     validateSchema: false,",
                        "     input(",
                        "          VendorNumber as integer,",
                        "          VendorName as string,",
                        "          PONumber as integer,",
                        "          PurchaseDollars as double,",
                        "          InvoiceDollars as double,",
                        "          Variance as double",
                        "     ),",
                        "     deletable:false,",
                        "     insertable:true,",
                        "     updateable:false,",
                        "     upsertable:false,",
                        "     truncate:true,",
                        "     format: 'table',",
                        "     skipDuplicateMapInputs: true,",
                        "     skipDuplicateMapOutputs: true,",
                        "     errorHandlingOption: 'stopOnFirstError') ~> sinkReconciliation"
                    ]
                }
            },
            "dependsOn": [
                "[concat(variables('factoryId'), '/datasets/ds_purchases')]",
                "[concat(variables('factoryId'), '/datasets/ds_vendor_invoice')]",
                "[concat(variables('factoryId'), '/datasets/ds_gold_invoice_reconciliation')]"
            ]
        },
        {
            "name": "[concat(parameters('factoryName'), '/df_sales_trend')]",
            "type": "Microsoft.DataFactory/factories/dataflows",
            "apiVersion": "2018-06-01",
            "properties": {
                "type": "MappingDataFlow",
                "typeProperties": {
                    "sources": [
                        {
                            "dataset": {
                                "referenceName": "ds_sales",
                                "type": "DatasetReference"
                            },
                            "name": "sales2"
                        }
                    ],
                    "sinks": [
                        {
                            "dataset": {
                                "referenceName": "ds_gold_sales_trend",
                                "type": "DatasetReference"
                            },
                            "name": "sinkSalesTrend"
                        }
                    ],
                    "transformations": [
                        {
                            "name": "extractMonth"
                        },
                        {
                            "name": "aggSalesTrend"
                        }
                    ],
                    "scriptLines": [
                        "source(output(",
                        "          InventoryId as string,",
                        "          Store as string,",
                        "          Brand as string,",
                        "          Description as string,",
                        "          Size as string,",
                        "          SalesQuantity as string,",
                        "          SalesDollars as string,",
                        "          SalesPrice as string,",
                        "          SalesDate as string,",
                        "          Volume as string,",
                        "          Classification as string,",
                        "          ExciseTax as string,",
                        "          VendorNo as string,",
                        "          VendorName as string",
                        "     ),",
                        "     allowSchemaDrift: true,",
                        "     validateSchema: false,",
                        "     ignoreNoFilesFound: false) ~> sales2",
                        "sales2 derive(SalesMonth = left(SalesDate, 7)) ~> extractMonth",
                        "extractMonth aggregate(groupBy(SalesMonth),",
                        "     TotalSalesDollars = sum(toDouble(SalesDollars)),",
                        "          TotalQuantity = sum(toInteger(SalesQuantity)),",
                        "          AvgSalesPrice = avg(toDouble(SalesPrice))) ~> aggSalesTrend",
                        "aggSalesTrend sink(allowSchemaDrift: true,",
                        "     validateSchema: false,",
                        "     input(",
                        "          SalesMonth as string,",
                        "          TotalSalesDollars as double,",
                        "          TotalQuantity as integer,",
                        "          AvgSalesPrice as double",
                        "     ),",
                        "     deletable:false,",
                        "     insertable:true,",
                        "     updateable:false,",
                        "     upsertable:false,",
                        "     truncate:true,",
                        "     format: 'table',",
                        "     skipDuplicateMapInputs: true,",
                        "     skipDuplicateMapOutputs: true,",
                        "     errorHandlingOption: 'stopOnFirstError') ~> sinkSalesTrend"
                    ]
                }
            },
            "dependsOn": [
                "[concat(variables('factoryId'), '/datasets/ds_sales')]",
                "[concat(variables('factoryId'), '/datasets/ds_gold_sales_trend')]"
            ]
        },
